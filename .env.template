# 飞书应用配置
# 获取方式：https://open.feishu.cn/app
FEISHU_APP_ID=cli_your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# 飞书文档ID
# 从文档URL中获取：https://my.feishu.cn/wiki/YOUR_DOCUMENT_ID
FEISHU_DOCUMENT_ID=your_document_id_here

# 可选：通知配置
# 是否发送完成通知
SEND_NOTIFICATION=false

# 通知接收用户（如流/飞书用户ID）
NOTIFICATION_USER=your_user_id_here
